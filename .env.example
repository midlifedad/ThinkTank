# Database
DATABASE_URL=postgresql+asyncpg://thinktank:thinktank@localhost:5432/thinktank
TEST_DATABASE_URL=postgresql+asyncpg://thinktank_test:thinktank_test@localhost:5433/thinktank_test

# Application
DEBUG=false
SERVICE_NAME=thinktank-api
CORS_ORIGINS=["*"]

# API Keys
# All API keys (Anthropic, ListenNotes, PodcastIndex, YouTube, Railway, etc.)
# are managed via the Admin Dashboard at /admin/api-keys
# They are stored in the system_config database table.
# Environment variables are supported as fallback for CI/testing only.

# Transcription
NEMO_CACHE_DIR=/app/.nemo_cache
AUDIO_TMP_DIR=/tmp/thinktank_audio
