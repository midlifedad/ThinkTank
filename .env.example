# Database
DATABASE_URL=postgresql+asyncpg://thinktank:thinktank@localhost:5432/thinktank
TEST_DATABASE_URL=postgresql+asyncpg://thinktank_test:thinktank_test@localhost:5433/thinktank_test

# Application
DEBUG=false
SERVICE_NAME=thinktank-api
CORS_ORIGINS=["*"]

# LLM Supervisor
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Podcast Discovery
LISTENNOTES_API_KEY=your-listennotes-api-key-here
PODCASTINDEX_API_KEY=your-podcastindex-api-key-here
PODCASTINDEX_API_SECRET=your-podcastindex-api-secret-here

# YouTube
YOUTUBE_API_KEY=your-youtube-api-key-here

# Twitter/X
TWITTER_BEARER_TOKEN=your-twitter-bearer-token-here

# Railway (for GPU scaling)
RAILWAY_API_KEY=your-railway-api-key-here
RAILWAY_GPU_SERVICE_ID=your-railway-gpu-service-id-here

# Transcription
NEMO_CACHE_DIR=/app/.nemo_cache
AUDIO_TMP_DIR=/tmp/thinktank_audio
